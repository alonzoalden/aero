{
  "name": "flight-ops-live-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx server/index.ts",
    "dev:all": "concurrently -n next,ws -c blue,green \"npm run dev\" \"npm run dev:server\"",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:model": "node scripts/verify-airplane-glb.mjs",
    "test": "node --import tsx --test server/*.test.ts"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.6",
    "@deck.gl/layers": "^9.3.6",
    "@deck.gl/mapbox": "^9.3.6",
    "@deck.gl/mesh-layers": "^9.3.6",
    "@deck.gl/react": "^9.3.6",
    "d3": "^7.9.0",
    "express": "^5.2.1",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
