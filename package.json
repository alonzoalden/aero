{
  "name": "flight-ops-live-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx server/index.ts",
    "dev:all": "concurrently -n next,ws -c blue,green \"npm run dev\" \"npm run dev:server\"",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:model": "node scripts/verify-airplane-glb.mjs"
  },
  "dependencies": {
    "@deck.gl/core": "^9.1.0",
    "@deck.gl/layers": "^9.1.0",
    "@deck.gl/mapbox": "^9.1.0",
    "@deck.gl/mesh-layers": "^9.3.6",
    "@deck.gl/react": "^9.1.0",
    "d3": "^7.9.0",
    "express": "^4.21.2",
    "maplibre-gl": "^5.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
